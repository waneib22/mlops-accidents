{
  "title": "Accidents MLOps — Monitoring API",
  "uid": "accidents-mlops",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "title": "Requêtes totales",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(http_requests_total{app_name=\"accidents_api\"})",
          "legendFormat": "Total"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Requêtes par seconde",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rate(http_requests_total{app_name=\"accidents_api\"}[1m]))",
          "legendFormat": "req/s"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "area" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Latence moyenne (p50)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{app_name=\"accidents_api\"}[1m])) by (le))",
          "legendFormat": "p50"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Latence p99",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{app_name=\"accidents_api\"}[1m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "options": { "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Volume de requêtes par endpoint",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (handler) (rate(http_requests_total{app_name=\"accidents_api\"}[1m]))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 6,
      "title": "Latence par endpoint (p95)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{app_name=\"accidents_api\"}[1m])))",
          "legendFormat": "{{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 7,
      "title": "Taux d'erreurs HTTP (4xx / 5xx)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (status_code) (rate(http_requests_total{app_name=\"accidents_api\", status_code=~\"4..|5..\"}[1m]))",
          "legendFormat": "HTTP {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2 }
        }
      }
    },
    {
      "id": 8,
      "title": "Requêtes en cours",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "http_requests_in_progress{app_name=\"accidents_api\"}",
          "legendFormat": "En cours"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2 } }
      }
    }
  ],
  "time": { "from": "now-30m", "to": "now" },
  "timepicker": {}
}
